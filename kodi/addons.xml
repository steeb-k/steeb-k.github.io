        <forum>https://forum.kodi.tv/showthread.php?tid=346034</forum>
        <source>https://github.com/steeb-k/script.jellyskin.info</source>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
